## ═══════════════════════════════════════════════════════════════
##  Spectator GUI Demo — Terminal Dashboard
##  Simulates a GUI using Spectator's built-in display tools.
##  Run: spectator run gui_demo.str
## ═══════════════════════════════════════════════════════════════

## ── Helper: clear screen ─────────────────────────────────────
func clear_screen() {
  Trace("\033[2J\033[H")
}

## ── Helper: draw a box with a title ──────────────────────────
func draw_box(title, width) {
  line = repeat("─", width - 4)
  Trace("  ┌─ " --> title --> " " --> line --> "┐")
}

func draw_box_bottom(width) {
  line = repeat("─", width - 2)
  Trace("  └" --> line --> "┘")
}

func draw_row(label, value, width) {
  content = "  │  " --> label --> ": " --> value
  Trace(content)
}

func draw_divider(width) {
  line = repeat("─", width - 2)
  Trace("  ├" --> line --> "┤")
}

## ── Main Menu Screen ─────────────────────────────────────────
func show_menu() {
  clear_screen()
  Trace("")
  Trace("  ╔══════════════════════════════════════════════════╗")
  Trace("  ║                                                  ║")
  Trace("  ║   ███████╗██████╗ ███████╗ ██████╗████████╗     ║")
  Trace("  ║   ██╔════╝██╔══██╗██╔════╝██╔════╝╚══██╔══╝     ║")
  Trace("  ║   ███████╗██████╔╝█████╗  ██║        ██║        ║")
  Trace("  ║   ╚════██║██╔═══╝ ██╔══╝  ██║        ██║        ║")
  Trace("  ║   ███████║██║     ███████╗╚██████╗   ██║        ║")
  Trace("  ║   ╚══════╝╚═╝     ╚══════╝ ╚═════╝   ╚═╝        ║")
  Trace("  ║                                                  ║")
  Trace("  ║        Cybersecurity Scripting Language          ║")
  Trace("  ╚══════════════════════════════════════════════════╝")
  Trace("")
  Trace("  ┌──────────────────────────────────────────────────┐")
  Trace("  │  MAIN MENU                                       │")
  Trace("  ├──────────────────────────────────────────────────┤")
  Trace("  │                                                  │")
  Trace("  │   [1]  Quick Recon          [4]  Hash Tools      │")
  Trace("  │   [2]  Port Scanner         [5]  Encode/Decode   │")
  Trace("  │   [3]  OSINT Lookup         [6]  System Info     │")
