## ─── Internal display helpers ────────────────────────────────────────────────

func _coffee_line() {
  Trace("  ─────────────────────────────────────────────────────────")
}

func _coffee_thick() {
  Trace("  ═════════════════════════════════════════════════════════")
}

func _coffee_ok(msg) {
  Trace("  [+]  " --> msg)
}

func _coffee_warn(msg) {
  Trace("  [!]  " --> msg)
}

func _coffee_info(msg) {
  Trace("  [*]  " --> msg)
}

func _coffee_hit(msg) {
  Trace("  [>>] " --> msg)
}

func _coffee_err(msg) {
  Trace("  [-]  ERROR: " --> msg)
}

func _coffee_section(label) {
  Trace("")
  Trace("  +--[ " --> label --> " ]")
}

## ─── coffee_banner ───────────────────────────────────────────────────────────

func coffee_banner(tool, version) {
  _coffee_thick()
  Trace("  [COFFEE]  " --> tool --> "  v" --> version)
  Trace("  Powered by Coffee Recon Library v1.0.0 for Spectator")
  _coffee_thick()
  _coffee_info("Started : " --> coffee_timestamp())
  _coffee_line()
  Trace("")
}

## ─── coffee_timestamp ────────────────────────────────────────────────────────

func coffee_timestamp() {
  return timestamp()
}

## ─── coffee_separator ────────────────────────────────────────────────────────

func coffee_separator(label) {
  Trace("")
  Trace("  ============================================================")
  Trace("  == " --> label)
  Trace("  ============================================================")
}

## ─── coffee_save ─────────────────────────────────────────────────────────────

func coffee_save(filename, content) {
  ts = coffee_timestamp()
  line = "[" --> ts --> "] " --> content --> "\n"
  try {
    appendFile(filename, line)
    _coffee_ok("Saved to: " --> filename)
  } catch e {
    _coffee_err("Could not save to " --> filename --> " — " --> e)
  }
}

## ─── coffee_recon ────────────────────────────────────────────────────────────

func coffee_recon(target) {
  coffee_separator("RECON  >>  " --> target)
  try {
    do --> Recon(target)
  } catch e {
    _coffee_err("Recon failed: " --> e)
  }
  Trace("")
}

## ─── coffee_deep_recon ───────────────────────────────────────────────────────

func coffee_deep_recon(target) {
  coffee_separator("DEEP RECON  >>  " --> target)

  _coffee_section("DNS Records")
  try {
    do --> Recon(target)
  } catch e {
    _coffee_err("DNS recon failed: " --> e)
  }

  _coffee_section("WHOIS")
  try {
    do --> WHOIs(target)
  } catch e {
    _coffee_err("WHOIs failed: " --> e)
  }

  _coffee_section("GeoIP")
  ips = []
  try {
    ips = resolve(target)
  } catch e {
    _coffee_err("resolve failed: " --> e)
  }

  if len(ips) == 0 {
    _coffee_warn("Could not resolve " --> target)
  } else {
    each ip : ips {
      _coffee_info("Geolocating " --> ip --> " ...")
      try {
        do --> GeoIP(ip)
      } catch e {
        _coffee_err("GeoIP failed for " --> ip --> ": " --> e)
      }
    }
  }
  Trace("")
}

## ─── coffee_portscan ─────────────────────────────────────────────────────────

func coffee_portscan(target, start, end) {
  coffee_separator("PORT SCAN  >>  " --> target --> "  (" --> str(start) --> "-" --> str(end) --> ")")
  try {
    do --> PortScan(target, start, end)
  } catch e {
    _coffee_err("PortScan failed: " --> e)
  }
  Trace("")
}

## ─── coffee_quick_ports ──────────────────────────────────────────────────────

func coffee_quick_ports(target) {
  coffee_separator("QUICK PORTS  >>  " --> target)
  _coffee_info("Checking top 20 ports...")
  Trace("")

  top = [21, 22, 23, 25, 53, 80, 110, 135, 139, 143, 443, 445, 3306, 3389, 5432, 6379, 8080, 8443, 9200, 27017]
  found = 0

  each p : top {
    try {
      if hasPort(target, p) {
        svc = _coffee_port_name(p)
        _coffee_hit("OPEN  " --> str(p) --> "/tcp   " --> svc)
        found += 1
      }
    } catch e {
      _coffee_err("Port check failed for " --> str(p) --> ": " --> e)
    }
  }

  Trace("")
  if found == 0 {
    _coffee_warn("No common ports open on " --> target)
  } else {
    _coffee_ok(str(found) --> " open port(s) found on " --> target)
  }
  Trace("")
}

## ─── _coffee_port_name ───────────────────────────────────────────────────────

func _coffee_port_name(port) {
  match str(port) {
    "21"    => { return "FTP" }
    "22"    => { return "SSH" }
    "23"    => { return "Telnet" }
    "25"    => { return "SMTP" }
    "53"    => { return "DNS" }
    "80"    => { return "HTTP" }
    "110"   => { return "POP3" }
    "135"   => { return "MSRPC" }
    "139"   => { return "NetBIOS" }
    "143"   => { return "IMAP" }
    "443"   => { return "HTTPS" }
    "445"   => { return "SMB" }
    "3306"  => { return "MySQL" }
    "3389"  => { return "RDP" }
    "5432"  => { return "PostgreSQL" }
    "6379"  => { return "Redis" }
    "8080"  => { return "HTTP-Alt" }
    "8443"  => { return "HTTPS-Alt" }
    "9200"  => { return "Elasticsearch" }
    "27017" => { return "MongoDB" }
    _       => { return "unknown" }
  }
}

