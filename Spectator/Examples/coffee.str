## ─── coffee_hash_all ─────────────────────────────────────────────────────────

func coffee_hash_all(data) {
  coffee_separator("HASH ANALYSIS")
  _coffee_info("Input  : " --> data)
  _coffee_info("Length : " --> str(len(data)) --> " characters")
  Trace("")
  Trace("  MD5    : " --> md5(data))
  Trace("  SHA1   : " --> sha1(data))
  Trace("  SHA256 : " --> sha256(data))
  Trace("  Base64 : " --> base64enc(data))
  Trace("")
}

## ─── coffee_banner_grab_multi ────────────────────────────────────────────────

func coffee_banner_grab_multi(host, ports) {
  coffee_separator("BANNER GRAB  >>  " --> host)
  each p : ports {
    try {
      if hasPort(host, p) {
        _coffee_info("Grabbing port " --> str(p) --> " ...")
        do --> BannerGrab(host, p)
      } else {
        _coffee_info("Port " --> str(p) --> " closed — skipping.")
      }
    } catch e {
      _coffee_err("BannerGrab port " --> str(p) --> " failed: " --> e)
    }
  }
  Trace("")
}

