## ─── coffee_score ────────────────────────────────────────────────────────────

func coffee_score(target) {
  coffee_separator("ATTACK SURFACE SCORE  >>  " --> target)

  points = 0
  findings = []

  ips = []
  try {
    ips = resolve(target)
  } catch e {
    _coffee_warn("Could not resolve " --> target)
  }

  if len(ips) == 0 {
    _coffee_warn("No IPs resolved — using target directly.")
    ips = append(ips, target)
  } else {
    _coffee_info("Resolved: " --> ips[0])
  }

  ## Check each port safely
  try {
    if hasPort(target, 80) {
      points += 1
      findings = append(findings, "HTTP (80) exposed")
    }
  } catch e { }
  try {
    if hasPort(target, 443) {
      points += 1
      findings = append(findings, "HTTPS (443) exposed")
    }
  } catch e { }
  try {
    if hasPort(target, 22) {
      points += 2
      findings = append(findings, "SSH (22) — brute-force risk")
    }
  } catch e { }
  try {
    if hasPort(target, 3389) {
      points += 3
      findings = append(findings, "RDP (3389) — critical exposure!")
    }
  } catch e { }
  try {
    if hasPort(target, 445) {
      points += 3
      findings = append(findings, "SMB (445) — lateral movement risk")
    }
  } catch e { }
  try {
    if hasPort(target, 23) {
      points += 4
      findings = append(findings, "Telnet (23) — plaintext protocol!")
    }
  } catch e { }
  try {
    if hasPort(target, 3306) {
      points += 4
      findings = append(findings, "MySQL (3306) publicly accessible!")
    }
  } catch e { }
  try {
    if hasPort(target, 5432) {
      points += 4
      findings = append(findings, "PostgreSQL (5432) publicly accessible!")
    }
  } catch e { }
  try {
    if hasPort(target, 6379) {
      points += 5
      findings = append(findings, "Redis (6379) — often unauthenticated!")
    }
  } catch e { }
  try {
    if hasPort(target, 27017) {
      points += 5
      findings = append(findings, "MongoDB (27017) — often unauthenticated!")
    }
  } catch e { }
  try {
    if hasPort(target, 9200) {
      points += 4
      findings = append(findings, "Elasticsearch (9200) exposed!")
    }
  } catch e { }
  try {
    status = httpGet("http://" --> target)
    if status == 200 {
      points += 1
      findings = append(findings, "HTTP returns 200 OK — active web service")
    }
  } catch e { }

  _coffee_section("Findings")
  if len(findings) == 0 {
    _coffee_ok("No significant exposure detected.")
  } else {
    n = 1
    each f : findings {
      Trace("  [" --> str(n) --> "] " --> f)
      n += 1
    }
  }

  level = "LOW"
  if points >= 3  { level = "MEDIUM" }
  if points >= 7  { level = "HIGH" }
  if points >= 12 { level = "CRITICAL" }

  Trace("")
  _coffee_section("Risk Score")
  Trace("  Points : " --> str(points))
  Trace("  Level  : " --> level)
  Trace("")

  if level == "CRITICAL" {
    _coffee_warn("CRITICAL exposure — multiple high-risk services found!")
  } elseif level == "HIGH" {
    _coffee_warn("HIGH risk — significant attack surface present.")
  } elseif level == "MEDIUM" {
    _coffee_info("MEDIUM risk — some exposure detected.")
  } else {
    _coffee_ok("LOW risk — minimal public exposure.")
  }

  Trace("")
  return level
}

## ─── coffee_full ─────────────────────────────────────────────────────────────

func coffee_full(target) {
  _coffee_thick()
  Trace("  [COFFEE] FULL RECON  >>  " --> target)
  _coffee_thick()
  Trace("")

  _coffee_info("Phase 1/7 — Attack surface score")
  risk = coffee_score(target)

  _coffee_info("Phase 2/7 — Deep DNS + WHOIS + GeoIP")
  coffee_deep_recon(target)

  _coffee_info("Phase 3/7 — Quick port scan")
  coffee_quick_ports(target)

  _coffee_info("Phase 4/7 — SSL certificate")
  coffee_ssl(target)

  _coffee_info("Phase 5/7 — Subdomain enumeration")
  coffee_subdomains(target)

  _coffee_info("Phase 6/7 — Web probe")
  coffee_web("http://" --> target)

  _coffee_info("Phase 7/7 — Directory discovery")
  coffee_dirbust("http://" --> target)

  _coffee_thick()
  Trace("  [COFFEE] FULL RECON COMPLETE")
  Trace("  Target    : " --> target)
  Trace("  Risk Level: " --> risk)
  Trace("  Timestamp : " --> coffee_timestamp())
  _coffee_thick()
  Trace("")
}

