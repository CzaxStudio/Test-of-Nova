## ─── coffee_ping_sweep ───────────────────────────────────────────────────────

func coffee_ping_sweep(hosts) {
  coffee_separator("PING SWEEP  >>  " --> str(len(hosts)) --> " hosts")
  alive = []

  each host : hosts {
    try {
      up = hasPort(host, 80) || hasPort(host, 22) || hasPort(host, 443) || hasPort(host, 445)
      if up {
        _coffee_hit("UP    " --> host)
        alive = append(alive, host)
      } else {
        _coffee_info("DOWN  " --> host)
      }
    } catch e {
      _coffee_err("Ping check failed for " --> host --> ": " --> e)
    }
  }

  Trace("")
  _coffee_ok(str(len(alive)) --> " host(s) responding out of " --> str(len(hosts)))
  Trace("")
  return alive
}

