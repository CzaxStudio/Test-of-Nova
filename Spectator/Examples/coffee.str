  _coffee_section("Port 22 (SSH)")
  try {
    do --> CIDRScan(cidr, 22)
  } catch e {
    _coffee_err("CIDRScan port 22 failed: " --> e)
  }

  _coffee_section("Port 445 (SMB)")
