## ─── coffee_fuzz ─────────────────────────────────────────────────────────────

func coffee_fuzz(url, wordlist) {
  coffee_separator("URL FUZZ  >>  " --> url)
  try {
    if len(wordlist) == 0 {
      _coffee_info("Using built-in wordlist")
      builtin = ["admin","login","dashboard","config","backup","uploads","api","v1","v2","test","dev",".git","wp-admin","phpinfo.php","robots.txt","sitemap.xml",".env","config.php","database.php","secret","private","data","dump","db","sql","logs","tmp","cache","old","bak"]
      do --> FuzzURL(url, builtin)
    } else {
      _coffee_info("Using custom wordlist (" --> str(len(wordlist)) --> " paths)")
      do --> FuzzURL(url, wordlist)
    }
  } catch e {
    _coffee_err("FuzzURL failed: " --> e)
  }
  Trace("")
}

