## ─── ghost_breach_check ──────────────────────────────────────────────────────
## Breach check links for an email or domain.
## Usage: ghost_breach_check("user@example.com")

func ghost_breach_check(email) {
  ghost_separator("BREACH CHECK  >>  " --> email)

  parts = split(email, "@")
  domain = ""
  if len(parts) == 2 { domain = parts[1] }

  enc = Encode(email, "url")

  ghost_section("Breach Databases (Public)")
  Trace("  HaveIBeenPwned : https://haveibeenpwned.com/account/" --> email)
  Trace("  DeHashed       : https://dehashed.com/search?query=" --> email)
  Trace("  IntelligenceX  : https://intelx.io/?s=" --> email)
  Trace("  Snusbase       : https://snusbase.com")
  Trace("  LeakCheck      : https://leakcheck.io")
  Trace("  Emailrep       : https://emailrep.io/" --> email)

  if domain != "" {
    ghost_section("Domain Breach Check")
    Trace("  HIBP Domain : https://haveibeenpwned.com/DomainSearch")
    Trace("  DeHashed    : https://dehashed.com/search?query=" --> domain)
  }

  ghost_section("Paste Sites")
  Trace("  Pastebin: https://www.google.com/search?q=site:pastebin.com+" --> enc)
  Trace("  GitHub  : https://gist.github.com/search?q=" --> enc)
  Trace("  Ghostbin: https://www.google.com/search?q=site:ghostbin.co+" --> enc)

  Trace("")
}

## ─── ghost_dork ──────────────────────────────────────────────────────────────
## Generate Google / Shodan / GitHub dorks for a target.
## Usage: ghost_dork("example.com", "backup OR config")

func ghost_dork(site, query) {
  ghost_separator("DORKS  >>  " --> site)

  ghost_section("Google Dorks — Copy/Paste into Google")
  dorks = [
    "site:" --> site --> " filetype:pdf",
    "site:" --> site --> " filetype:xls OR filetype:xlsx OR filetype:csv",
    "site:" --> site --> " filetype:sql OR filetype:db",
    "site:" --> site --> " filetype:log OR filetype:txt",
    "site:" --> site --> " filetype:env OR filetype:cfg OR filetype:conf",
    "site:" --> site --> " inurl:admin OR inurl:login OR inurl:dashboard",
    "site:" --> site --> " inurl:config OR inurl:backup OR inurl:.git",
    "site:" --> site --> " \"index of\" OR \"directory listing\"",
    "site:" --> site --> " intitle:\"admin panel\" OR intitle:\"dashboard\"",
    "site:" --> site --> " \"" --> query --> "\""
  ]

  each d, idx : dorks {
    Trace("  [" --> str(idx + 1) --> "] " --> d)
  }

  ghost_section("Shodan Dorks")
  Trace("  hostname:" --> site)
  Trace("  ssl.cert.subject.cn:" --> site)
  Trace("  http.title:\"" --> site --> "\"")
  Trace("  org:\"" --> site --> "\"")
  Trace("  http.favicon.hash:<hash>  (use faviconhash.com)")

  ghost_section("GitHub Dorks")
  Trace("  \"" --> site --> "\" password OR secret OR token")
  Trace("  \"" --> site --> "\" api_key OR api_secret OR client_secret")
  Trace("  \"" --> site --> "\" filename:.env OR filename:config.yml")
  Trace("  \"@" --> site --> "\" email")
  Trace("  org:" --> site --> " language:Python OR language:Go OR language:JS")

  ghost_section("LinkedIn Dorks")
  Trace("  site:linkedin.com/in \"" --> site --> "\"")
  Trace("  site:linkedin.com \"" --> site --> "\" engineer OR developer OR security")

  Trace("")
}

## ─── ghost_timeline ──────────────────────────────────────────────────────────
## Public historical timeline for a target.
## Usage: ghost_timeline("example.com")

func ghost_timeline(target) {
  ghost_separator("PUBLIC TIMELINE  >>  " --> target)

  ghost_section("Wayback Machine")
  Trace("  All snapshots : https://web.archive.org/web/*/" --> target)
  Trace("  First capture : https://web.archive.org/web/19960101000000*/" --> target)
  Trace("  Timeline view : https://timetravel.mementoweb.org/timemap/link/" --> target)
  Trace("  Google Cache  : https://webcache.googleusercontent.com/search?q=cache:" --> target)

  ghost_section("DNS History")
  Trace("  ViewDNS       : https://viewdns.info/iphistory/?domain=" --> target)
  Trace("  SecurityTrails: https://securitytrails.com/domain/" --> target --> "/history/a")
  Trace("  DNSHistory    : https://completedns.com/dns-history/#" --> target)

  ghost_section("Certificate History")
  Trace("  crt.sh        : https://crt.sh/?q=" --> target)
  Trace("  All certs     : https://crt.sh/?q=%25." --> target)

  ghost_section("News Archive")
  enc = Encode(target, "url")
  Trace("  Google News   : https://news.google.com/search?q=" --> enc)
  Trace("  GDELT Project : https://gdeltproject.org")

  Trace("")
}

## ─── ghost_links ─────────────────────────────────────────────────────────────
## Scrape + categorise all links from a public page.
## Usage: ghost_links("https://example.com")

func ghost_links(url) {
  ghost_separator("LINK EXTRACTION  >>  " --> url)
  try {
    resp = http("GET", url, {"timeout": 10000, "follow": true, "agent": "Mozilla/5.0"})
    if httpStatus(resp) == 200 {
      body   = httpBody(resp)
      links  = extractLinks(body, url)
      emails = extractEmails(body)
      forms  = extractForms(body)
      title  = extractTitle(body)

      ghost_section("Page Summary")
      ghost_info("Title  : " --> title)
      ghost_info("Links  : " --> str(len(links)))
      ghost_info("Emails : " --> str(len(emails)))
      ghost_info("Forms  : " --> str(len(forms)))

      if len(links) > 0 {
        ghost_section("All Links")
        each link : links { Trace("  " --> link) }
      }

      if len(emails) > 0 {
        ghost_section("Emails Found")
        each e : emails { ghost_hit(e) }
      }

      if len(forms) > 0 {
        ghost_section("Forms Found")
        each f : forms {
          ghost_info("action=" --> f["action"] --> " method=" --> f["method"] --> " fields=" --> str(f["fields"]))
        }
      }
    } else {
      ghost_err("HTTP " --> str(httpStatus(resp)))
    }
  } catch e {
    ghost_err("Link extraction: " --> e)
  }
  Trace("")
}

## ─── ghost_metadata ──────────────────────────────────────────────────────────
## Extract all public metadata from a webpage.
## Usage: ghost_metadata("https://example.com")

func ghost_metadata(url) {
  ghost_separator("PAGE METADATA  >>  " --> url)
  try {
    resp = http("GET", url, {"timeout": 10000, "follow": true, "agent": "Mozilla/5.0"})
    if httpStatus(resp) == 200 {
      body = httpBody(resp)

      ghost_section("Page Identity")
      ghost_info("Title       : " --> extractTitle(body))
      ghost_info("Description : " --> extractMeta(body, "description"))
      ghost_info("Author      : " --> extractMeta(body, "author"))
      ghost_info("Generator   : " --> extractMeta(body, "generator"))
      ghost_info("Keywords    : " --> extractMeta(body, "keywords"))
      ghost_info("Robots      : " --> extractMeta(body, "robots"))

      ghost_section("Open Graph Tags")
      ghost_info("og:title    : " --> extractMeta(body, "og:title"))
      ghost_info("og:desc     : " --> extractMeta(body, "og:description"))
      ghost_info("og:image    : " --> extractMeta(body, "og:image"))
      ghost_info("og:url      : " --> extractMeta(body, "og:url"))
      ghost_info("og:site_name: " --> extractMeta(body, "og:site_name"))

      ghost_section("Twitter Card")
      ghost_info("twitter:card   : " --> extractMeta(body, "twitter:card"))
      ghost_info("twitter:site   : " --> extractMeta(body, "twitter:site"))
      ghost_info("twitter:creator: " --> extractMeta(body, "twitter:creator"))

      ghost_section("Server Headers (Info Disclosure)")
      ghost_info("Server       : " --> httpHeader(resp, "server"))
      ghost_info("X-Powered-By : " --> httpHeader(resp, "x-powered-by"))
      ghost_info("Content-Type : " --> httpHeader(resp, "content-type"))
      ghost_info("X-Frame-Opts : " --> httpHeader(resp, "x-frame-options"))
      ghost_info("Last-Modified: " --> httpHeader(resp, "last-modified"))
    } else {
      ghost_err("HTTP " --> str(httpStatus(resp)))
    }
  } catch e {
    ghost_err("Metadata fetch: " --> e)
  }
  Trace("")
}

## ─── ghost_image_links ───────────────────────────────────────────────────────
## Reverse image search links for a public image URL.
## Usage: ghost_image_links("https://example.com/photo.jpg")

func ghost_image_links(url) {
  ghost_separator("REVERSE IMAGE SEARCH  >>  " --> url)
  enc = Encode(url, "url")

  ghost_section("Reverse Image Search Engines")
  Trace("  Google Images : https://images.google.com/searchbyimage?image_url=" --> enc)
  Trace("  TinEye        : https://tineye.com/search?url=" --> enc)
  Trace("  Yandex Images : https://yandex.com/images/search?url=" --> enc --> "&rpt=imageview")
  Trace("  Bing Visual   : https://www.bing.com/images/search?view=detailv2&iss=sbi&q=imgurl:" --> enc)

  ghost_section("Image Metadata Check")
  try {
    resp = http("GET", url, {"timeout": 10000})
    if httpStatus(resp) == 200 {
      ghost_ok("Image accessible — " --> str(resp["length"]) --> " bytes")
      ghost_info("Content-Type : " --> httpHeader(resp, "content-type"))
      ghost_info("Last-Modified: " --> httpHeader(resp, "last-modified"))
      ghost_info("Server       : " --> httpHeader(resp, "server"))
    } else {
      ghost_err("HTTP " --> str(httpStatus(resp)))
    }
  } catch e { ghost_err("Image fetch: " --> e) }

  Trace("")
}

## ─── ghost_report ────────────────────────────────────────────────────────────
## Generate HTML report from a Mission.
## Usage: ghost_report(mission_id, "report.html")

func ghost_report(mission_id, filename) {
  try {
    missionReport(mission_id, filename)
    ghost_ok("HTML report → " --> filename)
  } catch e {
    ghost_err("Report generation failed: " --> e)
  }
}

## ─── ghost_full ──────────────────────────────────────────────────────────────
## All-in-one OSINT on a domain target with full Mission tracking + report.
## Usage: report_file = ghost_full("example.com")

func ghost_full(target) {
  m = missionStart("Ghost OSINT — " --> target, target)

  missionStage(m, "Domain Intelligence")
  ghost_domain(target)
  missionFind(m, "INFO", "Domain recon complete", "Target: " --> target)

  missionStage(m, "IP Intelligence")
  ips = []
  try {
    ips = resolve(target)
    each ip : ips {
      ghost_ip(ip)
      missionFind(m, "INFO", "Resolved IP: " --> ip, "")
    }
  } catch e {
    missionNote(m, "Could not resolve: " --> e)
  }

  missionStage(m, "Web Metadata + Links")
  ghost_metadata("https://" --> target)
  ghost_links("https://" --> target)
  missionFind(m, "INFO", "Web metadata collected", "")

  missionStage(m, "Timeline + History")
  ghost_timeline(target)
  missionNote(m, "Wayback + DNS history links generated")

  missionStage(m, "Dork Generation")
  ghost_dork(target, "password OR credentials OR config OR backup OR secret")
  missionNote(m, "Google, Shodan, GitHub dorks generated")

  missionEnd(m)

  report = "ghost_report_" --> target --> "_" --> ghost_timestamp() --> ".html"
  missionReport(m, report)
  ghost_ok("Full OSINT report saved: " --> report)
  return report
}

## ─── Internal helpers ─────────────────────────────────────────────────────────

## Naive JSON field extractor for flat string fields.
func _ghost_json(json_str, key) {
  search = "\"" --> key --> "\":"
  if !contains(json_str, search) { return "" }
  parts = split(json_str, search)
  if len(parts) < 2 { return "" }
  after = trim(parts[1])
  if startsWith(after, "\"") {
    after = substr(after, 1, len(after))
    end_p = split(after, "\"")
    if len(end_p) > 0 { return end_p[0] }
  } elseif startsWith(after, "null") {
    return ""
  } else {
    end_p = split(after, ",")
    if len(end_p) > 0 { return trim(replace(end_p[0], "}", "")) }
  }
  return ""
}

## ─── End of Ghost OSINT Library v1.0.0 ───────────────────────────────────────
