## ═══════════════════════════════════════════════════════════════════════
##  Ghost Recon — Professional Pentesting Suite
##  Built with Spectator GUI
##
##  Features:
##    • Target management with scan history
##    • 8 scan modules with live progress
##    • Findings table with severity tagging
##    • Mission report export (HTML)
##    • Payload generator with copy support
##    • Encoder / decoder for all schemes
##    • Hash toolkit — identify, crack, compute
##    • Live settings — theme, accent, font
##
##  Run:   spectator run ghost_recon.str
##  Build: spectator build ghost_recon.str to GhostRecon.exe for windows
## ═══════════════════════════════════════════════════════════════════════

#Import Spec.GUI

open.window({
  "title":     "Ghost Recon — Spectator Pentest Suite",
  "width":     1200,
  "height":    780,
  "bg":        "#070b14",
  "accent":    "#00d4aa",
  "text":      "#e2e8f0",
  "font":      "Segoe UI",
  "radius":    "6",
  "padding":   "0",
  "resizable": true,
  "scrollbar": true
})

## ═══════════════════════════════════════════════════════════════════════
##  SIDEBAR
## ═══════════════════════════════════════════════════════════════════════

GUI.sidebar([
  {"id": "scan",     "label": "Scanner",    "icon": "⌖"},
  {"id": "findings", "label": "Findings",   "icon": "⚑"},
  {"id": "payloads", "label": "Payloads",   "icon": "⚡"},
  {"id": "encoder",  "label": "Encoder",    "icon": "⇄"},
  {"id": "hashes",   "label": "Hash Tools", "icon": "⊕"},
  {"id": "report",   "label": "Report",     "icon": "✦"},
  {"id": "settings", "label": "Settings",   "icon": "⚙"}
])

## ═══════════════════════════════════════════════════════════════════════
##  TAB: SCANNER
## ═══════════════════════════════════════════════════════════════════════

GUI.tabPanel("scan", {"active": true})
GUI.header("Scanner", {"subtitle": "Active reconnaissance — DNS · Ports · Web · SSL · OSINT"})

## Target row
GUI.label("Target", {"color": "#64748b", "margin": "0 0 4px 0"})
GUI.rowStart({"gap": "8px", "align": "center"})
GUI.input("target", "Domain, IP, or URL  (e.g. scanme.nmap.org)", {"width": "70%"})
GUI.dropdown("scan_module", [
  "Full Recon",
  "DNS Records",
  "Port Scan — Top 20",
  "HTTP Headers + Security Audit",
  "SSL Certificate",
  "Subdomain Enum",
  "Technology Detection",
  "GeoIP + IP Intel"
], {"width": "28%"})
GUI.rowEnd()
GUI.space(10)

## Action row
GUI.rowStart()
GUI.button("▶  Run Scan",   "run_scan",    {"color": "#00d4aa", "textColor": "#070b14"})
GUI.button("⬛  Stop",      "stop_scan",   {"color": "#1e293b", "outline": true})
GUI.button("✦  Add Finding","add_finding", {"color": "#f59e0b", "size": "sm"})
GUI.button("✕  Clear",      "clear_scan",  {"color": "#1e293b", "size": "sm"})
GUI.button("💾  Save",       "save_scan",   {"color": "#1e293b", "size": "sm"})
GUI.rowEnd()
GUI.space(10)
GUI.divider({"color": "#0f172a", "margin": "4px 0 10px 0"})

## Progress
GUI.rowStart({"gap": "12px", "align": "center"})
GUI.colStart({"width": "75%"})
GUI.progress("scan_bar", {"color": "#00d4aa", "height": 6})
GUI.colEnd()
GUI.colStart({"width": "24%"})
GUI.label(" ", {"id": "scan_status", "color": "#475569"})
GUI.colEnd()
GUI.rowEnd()
GUI.space(8)

## Output
GUI.output("scan_out", {"height": 420, "bg": "#020610"})
GUI.tabPanelEnd()

