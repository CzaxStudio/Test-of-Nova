##  HASH EVENTS
## ═══════════════════════════════════════════════════════════════════════

GUI.on("hash_identify", func() {
  h = GUI.get("hash_input")
  if h == "" { GUI.alert("Enter a hash first.")
   return }
  GUI.clear("hash_out")
  result = stripAnsi(str(HashIdentify(h)))
  GUI.print("hash_out", result)
})

GUI.on("hash_crack", func() {
  h = GUI.get("hash_input")
  if h == "" { GUI.alert("Enter a hash first.")
   return }
  GUI.clear("hash_out")
  result = stripAnsi(str(Crack(h, "md5")))
  GUI.print("hash_out", result)
})

GUI.on("hash_md5",    func() {
  t = GUI.get("hash_text")
  if t == "" { return }
  GUI.clear("hash_compute_out")
  GUI.print("hash_compute_out", "MD5:    " --> md5(t))
})
GUI.on("hash_sha1",   func() {
  t = GUI.get("hash_text")
  if t == "" { return }
  GUI.clear("hash_compute_out")
  GUI.print("hash_compute_out", "SHA-1:  " --> sha1(t))
})
GUI.on("hash_sha256", func() {
  t = GUI.get("hash_text")
  if t == "" { return }
  GUI.clear("hash_compute_out")
  GUI.print("hash_compute_out", "SHA-256: " --> sha256(t))
})
GUI.on("hash_b64",    func() {
  t = GUI.get("hash_text")
  if t == "" { return }
  GUI.clear("hash_compute_out")
  GUI.print("hash_compute_out", "Base64: " --> base64enc(t))
})

GUI.on("hash_compare", func() {
  a = trim(GUI.get("hash_cmp_a"))
  b = trim(GUI.get("hash_cmp_b"))
  GUI.clear("hash_cmp_out")
  if a == "" || b == "" { GUI.print("hash_cmp_out", "Enter both hashes.")
   return }
  if lower(a) == lower(b) {
    GUI.print("hash_cmp_out", "✓ MATCH — hashes are identical")
  } else {
    GUI.print("hash_cmp_out", "✕ NO MATCH — hashes differ")
  }
})

## ═══════════════════════════════════════════════════════════════════════
##  REPORT EVENTS
## ═══════════════════════════════════════════════════════════════════════

GUI.on("gen_report", func() {
  name     = GUI.get("rpt_name")
  target   = GUI.get("rpt_target")
  assessor = GUI.get("rpt_assessor")
  fname    = GUI.get("rpt_file")

  if name == "" || target == "" {
    GUI.alert("Fill in Mission Name and Target.")
    return
  }
  if fname == "" { fname = "pentest_report.html" }

  GUI.clear("report_out")
  GUI.print("report_out", "Building report...")

  m = missionStart(name, target)
  missionStage(m, "Assessment Summary")
  missionNote(m, "Assessed by: " --> assessor)
  missionNote(m, "Report generated: " --> timestamp())
  missionData(m, "scan_log", GUI.get("scan_out"))
  missionEnd(m)
  missionReport(m, fname)

  GUI.print("report_out", "")
  GUI.print("report_out", "✓ Report saved: " --> fname)
  GUI.print("report_out", "  Open in any browser to view.")
  GUI.notify("Ghost Recon", "Report saved: " --> fname)
})

