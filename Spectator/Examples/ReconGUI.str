## ═══════════════════════════════════════════════════════════════════════
##  SCANNER EVENTS
## ═══════════════════════════════════════════════════════════════════════

func gp(text) { GUI.print("scan_out", text) }
func status(text) { GUI.set("scan_status", text) }

GUI.on("clear_scan", func() {
  GUI.clear("scan_out")
  GUI.setProgress("scan_bar", 0)
  status("")
  GUI.setTitle("Ghost Recon — Spectator Pentest Suite")
})

GUI.on("save_scan", func() {
  out = GUI.get("scan_out")
  if out == "" { GUI.alert("Nothing to save.")
   return }
  target = GUI.get("target")
  fname  = "scan_" --> replace(target, ".", "_") --> "_" --> timestamp() --> ".txt"
  writeFile(fname, out)
  GUI.alert("Saved: " --> fname)
})

GUI.on("run_scan", func() {
  target = GUI.get("target")
  module = GUI.get("scan_module")
  if target == "" { GUI.alert("Enter a target first.")
   return }

  GUI.clear("scan_out")
  GUI.setProgress("scan_bar", 0.03)
  status("Running...")
  GUI.setTitle("Scanning: " --> target)

  gp("╔══════════════════════════════════════════════════════════╗")
  gp("║  GHOST RECON — " --> upper(module))
  gp("║  Target  : " --> target)
  gp("║  Time    : " --> timestamp())
  gp("╚══════════════════════════════════════════════════════════╝")
  gp("")

  match module {

    "Full Recon" => {
      gp("[ DNS ]")
      try {
        ips = resolve(target)
        each ip : ips { gp("  A        : " --> ip) }
      } catch e { gp("  error: " --> e) }
      GUI.setProgress("scan_bar", 0.15)

      try { mxs = lookupMX(target)
        each m : mxs  { gp("  MX       : " --> m) } } catch e {}
      try { nss = lookupNS(target)
        each n : nss  { gp("  NS       : " --> n) } } catch e {}
      try { txts = lookupTXT(target)
       each t : txts { gp("  TXT      : " --> truncate(t, 80)) } } catch e {}
      GUI.setProgress("scan_bar", 0.3)

      gp("")
      gp("[ TOP PORTS ]")
      top = [21,22,23,25,53,80,110,143,443,445,3306,3389,8080,8443]
      svcs = portServices()
      each p, idx : top {
        GUI.setProgress("scan_bar", 0.3 + idx * 0.02)
        try {
          if hasPort(target, p) { gp("  OPEN     : " --> str(p) --> "/tcp  " --> svcs[str(p)]) }
        } catch e {}
      }

      GUI.setProgress("scan_bar", 0.6)
      gp("")
      gp("[ HTTP ]")
      try {
        resp = http("GET", "https://" --> target, {"timeout": 8000, "follow": true})
        gp("  Status   : " --> str(httpStatus(resp)))
        gp("  Server   : " --> httpHeader(resp, "server"))
        gp("  Title    : " --> extractTitle(httpBody(resp)))
        gp("  HSTS     : " --> httpHeader(resp, "strict-transport-security"))
        gp("  CSP      : " --> truncate(httpHeader(resp, "content-security-policy"), 60))
      } catch e { gp("  HTTPS error: " --> e) }

      GUI.setProgress("scan_bar", 0.85)
      gp("")
      gp("[ GeoIP ]")
      try {
        ips2 = resolve(target)
        if len(ips2) > 0 {
          resp2 = http("GET", "http://ip-api.com/json/" --> ips2[0] --> "?fields=country,city,isp,org,as", {"timeout": 6000})
          body2 = httpBody(resp2)
          if contains(body2, "country") {
            pairs = [["country","Country"],["city","City"],["isp","ISP"],["org","Org"],["as","ASN"]]
            each pair : pairs {
              needle = "\"" --> pair[0] --> "\":"
              if contains(body2, needle) {
                parts = split(body2, needle)
                val = trim(replace(replace(split(trim(parts[1]), ",")[0], "\"", ""), "}", ""))
                if val != "" && val != "null" { gp("  " --> pair[1] --> ": " --> val) }
              }
            }
          }
        }
      } catch e { gp("  GeoIP error: " --> e) }
    }

    "DNS Records" => {
      gp("[ A Records ]")
      try { ips = resolve(target)
       each ip : ips { gp("  " --> ip) } } catch e { gp("  " --> e) }
      GUI.setProgress("scan_bar", 0.25)
      gp("")
      gp("[ MX Records ]")
      try { mxs = lookupMX(target)
       if len(mxs)==0{gp("  (none)")} else {each m:mxs{gp("  " --> m)}} } catch e { gp("  " --> e) }
      GUI.setProgress("scan_bar", 0.5)
      gp("")
      gp("[ NS Records ]")
      try { nss = lookupNS(target)
       if len(nss)==0{gp("  (none)")} else {each n:nss{gp("  " --> n)}} } catch e { gp("  " --> e) }
      GUI.setProgress("scan_bar", 0.7)
      gp("")
      gp("[ TXT Records ]")
      try { txts = lookupTXT(target)
       if len(txts)==0{gp("  (none)")} else {each t:txts{gp("  " --> truncate(t,100))}} } catch e { gp("  " --> e) }
      GUI.setProgress("scan_bar", 0.88)
      gp("")
      gp("[ CNAME ]")
      try {
        cn = lookupCNAME(target)
        if cn == "" || cn == target || cn == target --> "." { gp("  (no CNAME)") } else { gp("  " --> cn) }
      } catch e { gp("  " --> e) }
    }

    "Port Scan — Top 20" => {
      top20 = [21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,8888,9200,27017,11211]
      svcs  = portServices()
      found = 0
      gp("  Scanning " --> str(len(top20)) --> " ports...")
      gp("")
      each p, idx : top20 {
        GUI.setProgress("scan_bar", (idx + 1) / len(top20))
        try {
          if hasPort(target, p) {
            gp("  OPEN  " --> pad(str(p), 7) --> "  " --> svcs[str(p)])
            found += 1
          }
        } catch e {}
      }
      gp("")
      gp("  " --> str(found) --> " open port(s)")
    }

    "HTTP Headers + Security Audit" => {
      url = "https://" --> target
      GUI.setProgress("scan_bar", 0.2)
      try {
        resp = http("GET", url, {"timeout": 10000, "follow": true})
        gp("  Status   : " --> str(httpStatus(resp)))
        gp("")
        gp("[ Headers ]")
        hlist = ["server","x-powered-by","content-type","strict-transport-security",
                 "content-security-policy","x-frame-options","x-content-type-options",
                 "referrer-policy","access-control-allow-origin","cache-control"]
        each h : hlist {
          val = httpHeader(resp, h)
          if val != "" { gp("  " --> pad(h, 32) --> truncate(val, 60)) }
        }
        GUI.setProgress("scan_bar", 0.55)
        gp("")
        gp("[ Security Audit ]")
        score = 0
        checks = [
          ["strict-transport-security", "HSTS",    "HIGH"],
          ["content-security-policy",   "CSP",     "HIGH"],
          ["x-frame-options",           "X-Frame", "MEDIUM"],
          ["x-content-type-options",    "XCTO",    "LOW"],
          ["referrer-policy",           "Referer", "LOW"],
          ["permissions-policy",        "Perms",   "LOW"]
        ]
        each c : checks {
          val = httpHeader(resp, c[0])
          if val != "" { gp("  PASS      " --> c[1])
           score += 1 }
          else          { gp("  " --> c[2] --> "      " --> c[1] --> " missing") }
        }
        pct   = score * 100 / len(checks)
        grade = "F"
        if pct >= 83 { grade = "A" }
        if pct >= 66 && pct < 83 { grade = "B" }
        if pct >= 50 && pct < 66 { grade = "C" }
        if pct >= 33 && pct < 50 { grade = "D" }
        gp("")
        gp("  Score: " --> str(score) --> "/" --> str(len(checks)) --> "  Grade: " --> grade)
      } catch e { gp("  Error: " --> e) }
    }

    "SSL Certificate" => {
      GUI.setProgress("scan_bar", 0.3)
      try {
        resp = http("GET", "https://" --> target, {"timeout": 10000})
        gp("  HTTPS reachable — HTTP " --> str(httpStatus(resp)))
        gp("  Server: " --> httpHeader(resp, "server"))
        gp("")
        gp("  SSL Labs full report:")
        gp("  https://www.ssllabs.com/ssltest/analyze.html?d=" --> target)
        gp("")
        gp("  Certificate transparency (crt.sh):")
        gp("  https://crt.sh/?q=" --> target)
      } catch e { gp("  HTTPS error: " --> e) }
    }

    "Subdomain Enum" => {
      subs  = wordlist("common_subdomains")
      total = len(subs)
      found = []
      gp("  Checking " --> str(total) --> " subdomains...")
      gp("")
      each sub, idx : subs {
        GUI.setProgress("scan_bar", (idx + 1) / total)
        fqdn = sub --> "." --> target
        try {
          ips = resolve(fqdn)
          if len(ips) > 0 {
            gp("  FOUND  " --> fqdn --> "  →  " --> join(ips, ", "))
            found = append(found, fqdn)
          }
        } catch e {}
      }
      gp("")
      gp("  " --> str(len(found)) --> " subdomain(s) resolved")
    }

    "Technology Detection" => {
      GUI.setProgress("scan_bar", 0.2)
      try {
        resp = http("GET", "https://" --> target, {"timeout": 10000, "follow": true, "agent": "Mozilla/5.0"})
        body = httpBody(resp)
        gp("  Status   : " --> str(httpStatus(resp)))
        gp("  Title    : " --> extractTitle(body))
        gp("  Server   : " --> httpHeader(resp, "server"))
        gp("  X-Powered: " --> httpHeader(resp, "x-powered-by"))
        GUI.setProgress("scan_bar", 0.4)
        gp("")
        gp("[ Detected Technologies ]")
        body_low = lower(body)
        techs = [
          ["WordPress","wp-content"],["Joomla","joomla"],["Drupal","drupal"],
          ["Laravel","laravel"],["Django","csrfmiddlewaretoken"],["ASP.NET","__viewstate"],
          ["React","react"],["Angular","ng-version"],["Vue.js","vue.js"],
          ["jQuery","jquery"],["Bootstrap","bootstrap"],["Nginx","nginx"],
          ["Apache","apache"],["Cloudflare","cloudflare"],["PHP",".php"],
          ["Ruby on Rails","rails"],["Next.js","_next"],["Nuxt","__nuxt"]
        ]
        found_any = false
        each t : techs {
          if contains(body_low, lower(t[1])) { gp("  ✓ " --> t[0])
           found_any = true }
        }
        if !found_any { gp("  Nothing identified from signatures") }
        GUI.setProgress("scan_bar", 0.7)
        gp("")
        gp("[ Emails on Page ]")
        emails = extractEmails(body)
        if len(emails) == 0 { gp("  (none)") } else { each e : emails { gp("  " --> e) } }
      } catch e { gp("  Error: " --> e) }
    }

    "GeoIP + IP Intel" => {
      try {
        ips = resolve(target)
        if len(ips) == 0 { gp("  Could not resolve: " --> target) }
        else {
          each ip : ips {
            gp("  Resolved: " --> ip)
             gp("")
            GUI.setProgress("scan_bar", 0.3)
            try {
              resp = http("GET", "http://ip-api.com/json/" --> ip --> "?fields=status,country,regionName,city,isp,org,as,proxy,hosting,mobile", {"timeout": 8000})
              body = httpBody(resp)
              GUI.setProgress("scan_bar", 0.6)
              if contains(body, "success") {
                pairs = [["country","Country"],["regionName","Region"],["city","City"],["isp","ISP"],["org","Org"],["as","ASN"]]
                each pair : pairs {
                  needle = "\"" --> pair[0] --> "\":"
                  if contains(body, needle) {
                    parts = split(body, needle)
                    val = trim(replace(replace(split(trim(parts[1]), ",")[0], "\"", ""), "}", ""))
                    if val != "" && val != "null" { gp("  " --> pad(pair[1], 10) --> ": " --> val) }
                  }
                }
                gp("")
                gp("[ Threat Intel Links ]")
                gp("  Shodan    : https://www.shodan.io/host/" --> ip)
                gp("  GreyNoise : https://viz.greynoise.io/ip/" --> ip)
                gp("  AbuseIPDB : https://www.abuseipdb.com/check/" --> ip)
                gp("  VirusTotal: https://www.virustotal.com/gui/ip-address/" --> ip)
              } else { gp("  GeoIP lookup failed") }
            } catch e { gp("  GeoIP error: " --> e) }
          }
        }
      } catch e { gp("  Resolve error: " --> e) }
    }

    _ => { gp("  Unknown module") }
  }

  gp("")
  gp("══════════════════════════════════════════════════════════")
  gp("  Complete — " --> timestamp())
  GUI.setProgress("scan_bar", 1.0)
  status("Done")
  GUI.setTitle("Ghost Recon — Spectator Pentest Suite")
  GUI.notify("Ghost Recon", module --> " complete — " --> target)
})

## ═══════════════════════════════════════════════════════════════════════
##  FINDINGS EVENTS
## ═══════════════════════════════════════════════════════════════════════

finding_count = 0

func add_row_to_findings() {
  tgt  = GUI.get("finding_target")
  sev  = GUI.get("finding_sev")
  ttl  = GUI.get("finding_title")
  dtl  = GUI.get("finding_detail")
  if ttl == "" { GUI.alert("Enter a title for the finding.")
   return }
  finding_count += 1
  GUI.appendRow("findings_table", [str(finding_count), tgt, sev, ttl, dtl])
  GUI.set("finding_title", "")
  GUI.set("finding_detail", "")
}

GUI.on("add_finding",     func() { add_row_to_findings() })
GUI.on("add_finding_row", func() { add_row_to_findings() })
GUI.on("clear_findings",  func() {
  ok = GUI.confirm("Clear all findings?")
  if ok {
    GUI.clearTable("findings_table")
    finding_count = 0
  }
})
GUI.on("export_findings", func() {
  GUI.alert("Open the Report tab to generate a full HTML report.")
})

## ═══════════════════════════════════════════════════════════════════════
##  PAYLOAD EVENTS
## ═══════════════════════════════════════════════════════════════════════

GUI.on("gen_payloads", func() {
  ptype  = GUI.get("payload_type")
  filter = lower(GUI.get("payload_filter"))
  GUI.clear("payload_out")
  payloads = payloadList(ptype)
  shown = 0
  each p, idx : payloads {
    if filter == "" || contains(lower(p), filter) {
      GUI.print("payload_out", "[" --> str(idx + 1) --> "] " --> p)
      shown += 1
    }
  }
  GUI.print("payload_out", "")
  GUI.print("payload_out", "── " --> str(shown) --> " payloads shown for: " --> upper(ptype) --> " ──")
})

GUI.on("encode_payloads", func() {
  ptype    = GUI.get("payload_type")
  payloads = payloadList(ptype)
  GUI.clear("payload_out")
  each p, idx : payloads {
    encoded = Encode(p, "url")
    GUI.print("payload_out", "[" --> str(idx + 1) --> "] " --> encoded)
  }
})

GUI.on("encode_manual", func() {
  text   = GUI.get("payload_manual")
  scheme = GUI.get("payload_enc")
  if text == "" { GUI.alert("Paste a payload first.")
   return }
  try {
    result = Encode(text, scheme)
    GUI.clear("encode_out")
    GUI.print("encode_out", result)
  } catch e { GUI.clear("encode_out")
   GUI.print("encode_out", "Error: " --> e) }
})

## ═══════════════════════════════════════════════════════════════════════
##  ENCODER EVENTS
## ═══════════════════════════════════════════════════════════════════════

func do_encode(scheme) {
  text = GUI.get("enc_input")
  if text == "" { GUI.alert("Enter text first.")
   return }
  try {
    result = Encode(text, scheme)
    GUI.clear("enc_out")
    GUI.print("enc_out", result)
  } catch e { GUI.clear("enc_out")
   GUI.print("enc_out", "Error: " --> e) }
}

func do_decode(scheme) {
  text = GUI.get("enc_input")
  if text == "" { GUI.alert("Enter text first.")
   return }
  try {
    result = Decode(text, scheme)
    GUI.clear("enc_out")
    GUI.print("enc_out", result)
  } catch e { GUI.clear("enc_out")
   GUI.print("enc_out", "Error: " --> e) }
}

GUI.on("enc_url",     func() { do_encode("url") })
GUI.on("enc_url2",    func() { do_encode("url2") })
GUI.on("enc_b64",     func() { do_encode("b64") })
GUI.on("enc_html",    func() { do_encode("html") })
GUI.on("enc_hex",     func() { do_encode("hex") })
GUI.on("enc_unicode", func() { do_encode("unicode") })
GUI.on("enc_rot13",   func() { do_encode("rot13") })
GUI.on("dec_url",     func() { do_decode("url") })
GUI.on("dec_b64",     func() { do_decode("b64") })
GUI.on("dec_html",    func() { do_decode("html") })
GUI.on("dec_hex",     func() { do_decode("hex") })
GUI.on("dec_rot13",   func() { do_decode("rot13") })
GUI.on("enc_swap",    func() {
  out = GUI.get("enc_out")
  if out != "" { GUI.set("enc_input", out)
   GUI.clear("enc_out") }
})

